POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=prozorro
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=SuperSecretRedisPassword123!

# Set to MAIN for the primary server that fetches tenders (default)
# Set to WORKER for additional servers that only process the queue
APP_ROLE=MAIN

# Speed config for workers
WORKER_CONCURRENCY=50
WORKER_REQUESTS_PER_SECOND=50
WORKER_LOCK_DURATION_MS=300000
WORKER_DB_CONCURRENCY=2
MAIN_QUEUE_FAILED_JOBS_TO_KEEP=1000

# Start syncing from this date if no offset is saved (ISO date or Prozorro offset string)
SYNC_START_DATE=2025-01-01

# API Authentication Key
API_KEY=your_secure_api_key_for_bot_and_dashboard

# Legacy Google Document AI (no longer used in the text-first extraction flow)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-document-ai.json
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_DOCUMENT_AI_LOCATION=eu
GOOGLE_DOCUMENT_AI_FORM_PROCESSOR_ID=
GOOGLE_DOCUMENT_AI_LAYOUT_PROCESSOR_ID=

# Mistral OCR fallback
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
MISTRAL_API_BASE_URL=https://api.mistral.ai

# Gemini AI extraction from extracted text
GEMINI_API_KEY=
GEMINI_CONTRACT_EXTRACTION_MODEL=gemini-2.5-flash-lite
GEMINI_CONTRACT_EXTRACTION_MAX_CHARS=60000
GEMINI_CONTRACT_AUDIT_MODEL=gemini-2.5-flash-lite
GEMINI_CONTRACT_AUDIT_MAX_ITEMS=20

# Optional usage/cost estimation overrides (USD)
GEMINI_TOKEN_INPUT_COST_PER_1M_USD=0.1
GEMINI_TOKEN_OUTPUT_COST_PER_1M_USD=0.4
GEMINI_GROUNDED_SEARCH_COST_PER_REQUEST_USD=0
MISTRAL_OCR_COST_PER_PAGE_USD=0.002

# Telegram bot
TELEGRAM_BOT_TOKEN=
