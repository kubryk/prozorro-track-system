// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tender {
  id           String        @id
  tenderID     String?       // Public ID, e.g., UA-2025-01-01-000107-a
  title        String?
  status       String?
  amount                Float?
  currency              String?
  year             Int           // To filter by 2025/2026
  dateModified     DateTime
  dateCreated      DateTime?
  
  // Official Prozorro periods
  tenderPeriodStart    DateTime?
  tenderPeriodEnd      DateTime?
  enquiryPeriodStart   DateTime?
  enquiryPeriodEnd     DateTime?
  auctionPeriodStart   DateTime?
  awardPeriodStart     DateTime?

  syncStatus       String        @default("FULL") // "FULL", "PARTIAL", or "FAILED"
  
  customerEdrpou   String?
  customerName     String?

  // Relations
  contracts        Contract[]

  @@index([customerEdrpou])
  @@index([tenderID])
  @@index([year])
  @@index([status])
  @@index([dateModified])
  @@index([syncStatus])
  @@index([tenderPeriodStart])
  @@index([tenderPeriodEnd])
  @@index([enquiryPeriodStart])
  @@index([enquiryPeriodEnd])
  @@index([auctionPeriodStart])
  @@index([awardPeriodStart])
}

model Contract {
  id                      String        @id
  contractID              String?       // Public ID
  status                  String?
  amount                  Float?
  currency                String?
  valueAddedTaxIncluded   Boolean?
  amountNet               Float?
  dateSigned              DateTime?
  date                    DateTime?
  dateModified            DateTime?
  dateCreated             DateTime?

  supplierEdrpou          String?
  supplierName            String?

  tenderId                String
  tender                  Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([supplierEdrpou])
  @@index([contractID])
  @@index([tenderId])
  @@index([status])
  @@index([dateModified])
  @@index([dateSigned])
}



model SyncState {
  id          Int      @id @default(1)
  lastOffset  String?
  updatedAt   DateTime @updatedAt
}
