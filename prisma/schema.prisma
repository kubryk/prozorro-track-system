// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tender {
  id           String        @id
  tenderID     String?       // Public ID, e.g., UA-2025-01-01-000107-a
  title        String?
  status       String?
  amount                Float?
  currency              String?
  year             Int           // To filter by 2025/2026
  dateModified     DateTime
  dateCreated      DateTime      @default(now())
  syncStatus       String        @default("FULL") // "FULL" or "PARTIAL"
  
  customerEdrpou   String?
  customerName     String?

  // Relations
  contracts        Contract[]

  @@index([customerEdrpou])
}

model Contract {
  id                      String        @id
  contractID              String?       // Public ID
  status                  String?
  amount                  Float?
  currency                String?
  valueAddedTaxIncluded   Boolean?
  amountNet               Float?
  dateSigned              DateTime?
  date                    DateTime?
  dateModified            DateTime?
  dateCreated             DateTime?

  supplierEdrpou          String?
  supplierName            String?

  tenderId                String
  tender                  Tender        @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@index([supplierEdrpou])
}



model SyncState {
  id          Int      @id @default(1)
  lastOffset  String?
  updatedAt   DateTime @updatedAt
}
